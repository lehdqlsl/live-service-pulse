<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pulse — Uptime Monitor</title>
  <link rel="stylesheet" href="/style.css">
  <link id="favicon" rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'><circle cx='8' cy='8' r='8' fill='%2322c55e'/></svg>">
</head>
<body>
  <header>
    <div class="header-content">
      <div class="logo">
        <span class="pulse-dot"></span>
        <h1>Pulse</h1>
      </div>
      <nav class="main-nav">
        <a href="/" class="nav-link active">Dashboard</a>
        <a href="/status" class="nav-link">Status</a>
        <a href="/reports" class="nav-link">Report</a>
        <a href="/metrics" class="nav-link" target="_blank">Metrics</a>
      </nav>
      <div class="header-right">
        <span class="sse-status" id="sseStatus" title="Live connection status">
          <span class="sse-dot" id="sseDot"></span>
          <span id="lastUpdated">Connected</span>
        </span>
        <span class="real-time-clock" id="clock"></span>
      </div>
    </div>
  </header>

  <main>
    <!-- Stats Cards -->
    <section class="stats-grid">
      <div class="stat-card">
        <div class="stat-value"><%= stats.active_monitors || 0 %></div>
        <div class="stat-label">Active Monitors</div>
      </div>
      <div class="stat-card stat-card-uptime">
        <div class="stat-value stat-value-large"><%= stats.overall_uptime || '—' %><% if (stats.overall_uptime) { %>%<% } %></div>
        <div class="stat-label">Overall Uptime (24h)</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= stats.avg_response_time || '—' %><% if (stats.avg_response_time) { %><span class="stat-unit">ms</span><% } %></div>
        <div class="stat-label">Avg Response</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= stats.total_checks || 0 %></div>
        <div class="stat-label">Checks (24h)</div>
      </div>
    </section>

    <!-- Add Monitor Form -->
    <section class="add-monitor" id="addMonitorSection">
      <h2>Add Monitor <span class="shortcut-hint">(press <kbd>n</kbd>)</span></h2>
      <form id="addForm" class="add-form">
        <input type="text" name="name" placeholder="Name (e.g. Google)" required>
        <input type="url" name="url" placeholder="https://example.com" required>
        <input type="number" name="interval" placeholder="Interval (s)" value="60" min="10" max="3600">
        <input type="text" name="tags" placeholder="Tags (comma-separated)">
        <div class="add-form-row">
          <label class="checkbox-label">
            <input type="checkbox" id="bodyCheckEnabled" name="body_check_enabled">
            Body validation
          </label>
          <input type="text" id="expectedBodyRegex" name="expected_body_regex" placeholder="Expected regex" style="display:none;">
        </div>
        <div class="add-form-row">
          <input type="number" name="max_retries" placeholder="Retries (0-5)" value="0" min="0" max="5" style="width:120px;">
          <input type="number" name="alert_threshold_ms" placeholder="Alert threshold (ms)" min="0" style="width:160px;">
          <label class="checkbox-label">
            <input type="checkbox" name="alert_enabled">
            Alert on slow
          </label>
        </div>
        <div class="add-form-row">
          <select name="group_id" style="width:200px;">
            <option value="">No Group</option>
            <% groups.forEach(function(g) { %>
              <option value="<%= g.id %>"><%= g.name %></option>
            <% }); %>
          </select>
        </div>
        <button type="submit">Add</button>
      </form>
    </section>

    <!-- Tag Filter Bar -->
    <% if (allTags.length > 0) { %>
      <section class="filter-bar">
        <span class="filter-label">Filter by tag:</span>
        <button class="tag-filter-btn active" data-tag="all">All</button>
        <% allTags.forEach(function(tag) { %>
          <button class="tag-filter-btn" data-tag="<%= tag %>"><%= tag %></button>
        <% }); %>
      </section>
    <% } %>

    <!-- Search Bar -->
    <section class="search-section">
      <div class="search-input-wrapper">
        <input type="text" id="monitorSearch" class="search-input" placeholder="Search monitors by name or URL... (press /)" autocomplete="off">
      </div>
    </section>

    <!-- Monitors Table -->
    <section class="monitors-section">
      <div class="monitors-section-header">
        <h2>Monitors</h2>
        <div class="monitors-section-actions">
          <a href="/api/export/monitors" class="export-btn" title="Export All (JSON)">Export All (JSON)</a>
          <button class="bulk-delete-btn" id="bulkDeleteBtn" style="display:none;">Delete Selected</button>
        </div>
      </div>
      <% if (monitors.length === 0) { %>
        <div class="empty-state">
          <p>No monitors yet. Add one above to get started.</p>
        </div>
      <% } else { %>
        <%
          // Group monitors by group_id
          var groupedMonitors = {};
          var ungrouped = [];
          monitors.forEach(function(m) {
            if (m.group_id) {
              if (!groupedMonitors[m.group_id]) groupedMonitors[m.group_id] = [];
              groupedMonitors[m.group_id].push(m);
            } else {
              ungrouped.push(m);
            }
          });
        %>
        <% groups.forEach(function(group) { %>
          <% if (groupedMonitors[group.id] && groupedMonitors[group.id].length > 0) { %>
            <div class="monitor-group-header" data-group-id="<%= group.id %>">
              <span class="group-color-dot" style="background: <%= group.color %>"></span>
              <h3><%= group.name %></h3>
              <% if (group.description) { %><span class="group-description"><%= group.description %></span><% } %>
              <span class="group-count"><%= groupedMonitors[group.id].length %> monitor<%= groupedMonitors[group.id].length !== 1 ? 's' : '' %></span>
            </div>
            <div class="monitors-grid">
              <% groupedMonitors[group.id].forEach(function(m) { %>
                <%- include('_monitor-card', { m, sparklines, sslData, uptimeBars, maintenanceMonitorIds }) %>
              <% }); %>
            </div>
          <% } %>
        <% }); %>
        <% if (ungrouped.length > 0) { %>
          <% if (groups.length > 0 && Object.keys(groupedMonitors).length > 0) { %>
            <div class="monitor-group-header">
              <span class="group-color-dot" style="background: #64748b"></span>
              <h3>Ungrouped</h3>
              <span class="group-count"><%= ungrouped.length %> monitor<%= ungrouped.length !== 1 ? 's' : '' %></span>
            </div>
          <% } %>
          <div class="monitors-grid">
            <% ungrouped.forEach(function(m) { %>
              <%- include('_monitor-card', { m, sparklines, sslData, uptimeBars, maintenanceMonitorIds }) %>
            <% }); %>
          </div>
        <% } %>
      <% } %>
    </section>

    <!-- Incidents Timeline -->
    <section class="incidents-section">
      <h2>Recent Incidents</h2>
      <% if (incidents.length === 0) { %>
        <div class="empty-state">
          <p>No incidents recorded. All systems operational.</p>
        </div>
      <% } else { %>
        <div class="incidents-list">
          <% incidents.forEach(function(inc) { %>
            <div class="incident-card <%= inc.resolved_at ? 'resolved' : 'ongoing' %>">
              <div class="incident-status">
                <span class="incident-dot <%= inc.resolved_at ? 'resolved' : 'ongoing' %>"></span>
              </div>
              <div class="incident-details">
                <div class="incident-header">
                  <strong><%= inc.monitor_name %></strong>
                  <span class="incident-badge <%= inc.resolved_at ? 'resolved' : 'ongoing' %>">
                    <%= inc.resolved_at ? 'Resolved' : 'Ongoing' %>
                  </span>
                </div>
                <div class="incident-meta">
                  <span>Started: <%= new Date(inc.started_at).toLocaleString() %></span>
                  <% if (inc.resolved_at) { %>
                    <span>Resolved: <%= new Date(inc.resolved_at).toLocaleString() %></span>
                    <span>Duration: <%= inc.duration_seconds < 60 ? inc.duration_seconds + 's' : Math.floor(inc.duration_seconds / 60) + 'm ' + (inc.duration_seconds % 60) + 's' %></span>
                  <% } %>
                </div>
                <div class="incident-url"><%= inc.monitor_url %></div>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>

    <!-- Webhooks -->
    <section class="webhooks-section">
      <h2>Webhooks</h2>
      <form id="webhookForm" class="add-form">
        <input type="url" name="url" placeholder="https://example.com/webhook" required>
        <input type="text" name="events" placeholder="Events (default: down,up)" value="down,up">
        <button type="submit">Add Webhook</button>
      </form>
      <% if (webhooks.length > 0) { %>
        <div class="webhooks-list">
          <% webhooks.forEach(function(wh) { %>
            <div class="webhook-card">
              <div class="webhook-info">
                <div class="webhook-url"><%= wh.url %></div>
                <div class="webhook-meta">
                  <span class="webhook-events"><%= wh.events %></span>
                  <span>Added: <%= new Date(wh.created_at).toLocaleString() %></span>
                </div>
              </div>
              <button class="delete-btn webhook-delete" data-id="<%= wh.id %>" title="Delete">&times;</button>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>

    <!-- Notification Channels -->
    <section class="channels-section">
      <h2>Notification Channels</h2>
      <form id="channelForm" class="add-form">
        <select name="type" required>
          <option value="webhook">Webhook</option>
          <option value="slack">Slack</option>
          <option value="discord">Discord</option>
        </select>
        <input type="url" name="url" placeholder="Webhook / Slack / Discord URL" required>
        <button type="submit">Add Channel</button>
      </form>
      <% if (channels.length > 0) { %>
        <div class="webhooks-list" style="margin-top: 1rem;">
          <% channels.forEach(function(ch) { %>
            <div class="webhook-card">
              <div class="webhook-info">
                <div class="webhook-url">
                  <span class="channel-type-badge <%= ch.type %>"><%= ch.type %></span>
                  <%= ch.config.url %>
                </div>
                <div class="webhook-meta">
                  <span><%= ch.enabled ? 'Enabled' : 'Disabled' %></span>
                  <span>Added: <%= new Date(ch.created_at).toLocaleString() %></span>
                </div>
              </div>
              <button class="delete-btn channel-delete" data-id="<%= ch.id %>" title="Delete">&times;</button>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>

    <!-- API Keys -->
    <section class="api-keys-section">
      <h2>API Keys</h2>
      <form id="apiKeyForm" class="add-form">
        <input type="text" name="name" placeholder="Key name (e.g. CI/CD)" required>
        <button type="submit">Generate Key</button>
      </form>
      <% if (apiKeys.length > 0) { %>
        <div class="webhooks-list" style="margin-top: 1rem;">
          <% apiKeys.forEach(function(k) { %>
            <div class="webhook-card">
              <div class="webhook-info">
                <div class="webhook-url"><%= k.name %></div>
                <div class="webhook-meta">
                  <span>Created: <%= new Date(k.created_at).toLocaleString() %></span>
                  <span>Last used: <%= k.last_used_at ? new Date(k.last_used_at).toLocaleString() : 'Never' %></span>
                </div>
              </div>
              <button class="delete-btn api-key-delete" data-id="<%= k.id %>" title="Revoke">&times;</button>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>
  </main>

  <footer>
    <p>Pulse v1.9.0 &middot; Live updates via SSE</p>
  </footer>

  <script>
    // Real-time clock
    function updateClock() {
      const now = new Date();
      document.getElementById('clock').textContent = now.toLocaleTimeString();
    }
    updateClock();
    setInterval(updateClock, 1000);

    // ── Last Updated Counter ──
    let lastUpdateTime = Date.now();
    const lastUpdatedEl = document.getElementById('lastUpdated');
    const sseDotEl = document.getElementById('sseDot');

    function updateLastUpdated() {
      const seconds = Math.floor((Date.now() - lastUpdateTime) / 1000);
      if (seconds < 5) {
        lastUpdatedEl.textContent = 'Just now';
      } else {
        lastUpdatedEl.textContent = seconds + 's ago';
      }
      // Color coding
      const status = document.getElementById('sseStatus');
      status.classList.remove('stale', 'disconnected');
      if (seconds > 120) {
        status.classList.add('disconnected');
      } else if (seconds > 60) {
        status.classList.add('stale');
      }
    }
    setInterval(updateLastUpdated, 1000);

    // ── Favicon Status ──
    function setFavicon(allUp) {
      const color = allUp ? '%2322c55e' : '%23ef4444';
      document.getElementById('favicon').href =
        "data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'><circle cx='8' cy='8' r='8' fill='" + color + "'/></svg>";
    }

    // Track monitor states for favicon
    const monitorStates = {};
    document.querySelectorAll('.monitor-card').forEach(function(card) {
      const id = card.dataset.id;
      monitorStates[id] = card.classList.contains('up');
    });
    function updateFavicon() {
      const ids = Object.keys(monitorStates);
      if (ids.length === 0) { setFavicon(true); return; }
      const allUp = ids.every(function(id) { return monitorStates[id]; });
      setFavicon(allUp);
    }
    updateFavicon();

    // ── Response Time Chart Data ──
    const chartData = {};
    document.querySelectorAll('.rt-chart').forEach(function(svg) {
      const container = svg.parentElement;
      const id = container.id.replace('rtChart-', '');
      try {
        chartData[id] = JSON.parse(svg.getAttribute('data-points') || '[]');
      } catch(e) {
        chartData[id] = [];
      }
    });

    function renderChart(monitorId) {
      const container = document.getElementById('rtChart-' + monitorId);
      if (!container) return;
      const svg = container.querySelector('.rt-chart');
      if (!svg) return;
      const points = chartData[monitorId] || [];
      if (points.length < 2) return;

      const cMax = Math.max.apply(null, points);
      const cMin = Math.min.apply(null, points);
      const cRange = cMax - cMin || 1;

      const coords = points.map(function(v, i) {
        return {
          x: (i / (points.length - 1) * 200).toFixed(1),
          y: (38 - ((v - cMin) / cRange) * 34).toFixed(1),
          val: v
        };
      });
      const polyStr = coords.map(function(c) { return c.x + ',' + c.y; }).join(' ');
      const fillStr = '0,40 ' + polyStr + ' 200,40';

      // Use unique gradient id
      const gradId = 'chartGrad-' + monitorId;
      svg.innerHTML =
        '<defs><linearGradient id="' + gradId + '" x1="0" y1="0" x2="0" y2="1">' +
        '<stop offset="0%" stop-color="var(--accent)" stop-opacity="0.3"/>' +
        '<stop offset="100%" stop-color="var(--accent)" stop-opacity="0.02"/>' +
        '</linearGradient></defs>' +
        '<polygon fill="url(#' + gradId + ')" points="' + fillStr + '" />' +
        '<polyline fill="none" stroke="var(--accent)" stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round" points="' + polyStr + '" />' +
        coords.map(function(c) {
          return '<circle class="rt-dot" cx="' + c.x + '" cy="' + c.y + '" r="2.5" fill="var(--accent)"><title>' + c.val + 'ms</title></circle>';
        }).join('');
    }

    // ── Flash animation helper ──
    function flashElement(el) {
      el.classList.remove('sse-flash');
      void el.offsetWidth; // reflow
      el.classList.add('sse-flash');
    }

    // ── SSE Connection ──
    let pollTimer = null;
    function connectSSE() {
      const es = new EventSource('/api/events');

      es.addEventListener('check', function(e) {
        const d = JSON.parse(e.data);
        lastUpdateTime = Date.now();

        // Update monitor card
        const card = document.querySelector('.monitor-card[data-id="' + d.monitorId + '"]');
        if (card) {
          // Update status classes
          card.classList.remove('up', 'down', 'pending');
          card.classList.add(d.isUp ? 'up' : 'down');

          // Update status indicator
          const indicator = card.querySelector('.status-indicator');
          if (indicator) {
            indicator.classList.remove('up', 'down', 'pending');
            indicator.classList.add(d.isUp ? 'up' : 'down');
          }

          // Update metric values
          const statusEl = document.getElementById('status-' + d.monitorId);
          if (statusEl) { statusEl.textContent = d.isUp ? 'UP' : 'DOWN'; flashElement(statusEl); }

          const responseEl = document.getElementById('response-' + d.monitorId);
          if (responseEl) { responseEl.textContent = d.responseTime + 'ms'; flashElement(responseEl); }

          const codeEl = document.getElementById('code-' + d.monitorId);
          if (codeEl && d.statusCode) { codeEl.textContent = d.statusCode; flashElement(codeEl); }

          // Flash the card
          flashElement(card);

          // Update chart data
          if (!chartData[d.monitorId]) chartData[d.monitorId] = [];
          chartData[d.monitorId].push(d.responseTime);
          if (chartData[d.monitorId].length > 20) chartData[d.monitorId].shift();
          renderChart(d.monitorId);

          // Update favicon state
          monitorStates[d.monitorId] = d.isUp;
          updateFavicon();
        }
      });

      es.addEventListener('incident', function(e) {
        const d = JSON.parse(e.data);
        lastUpdateTime = Date.now();
      });

      es.onopen = function() {
        sseDotEl.classList.remove('disconnected');
        sseDotEl.classList.add('connected');
        if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
      };

      es.onerror = function() {
        sseDotEl.classList.remove('connected');
        sseDotEl.classList.add('disconnected');
        // Fallback: poll every 30s
        if (!pollTimer) {
          pollTimer = setInterval(function() {
            window.location.reload();
          }, 30000);
        }
      };
    }
    connectSSE();

    // Keyboard shortcut: 'n' to focus add form
    document.addEventListener('keydown', function(e) {
      if (e.key === 'n' && !e.ctrlKey && !e.metaKey && !e.altKey && e.target.tagName !== 'INPUT' && e.target.tagName !== 'TEXTAREA') {
        e.preventDefault();
        var nameInput = document.querySelector('#addForm input[name="name"]');
        if (nameInput) {
          document.getElementById('addMonitorSection').scrollIntoView({ behavior: 'smooth' });
          nameInput.focus();
        }
      }
    });

    // Body check toggle
    document.getElementById('bodyCheckEnabled').addEventListener('change', function() {
      document.getElementById('expectedBodyRegex').style.display = this.checked ? '' : 'none';
    });

    // Tag filter
    document.querySelectorAll('.tag-filter-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.tag-filter-btn').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        var tag = btn.dataset.tag;
        document.querySelectorAll('.monitor-card').forEach(function(card) {
          if (tag === 'all') {
            card.style.display = '';
          } else {
            var cardTags = (card.dataset.tags || '').split(',').map(function(t) { return t.trim(); });
            card.style.display = cardTags.includes(tag) ? '' : 'none';
          }
        });
      });
    });

    document.getElementById('addForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const data = {
        name: form.name.value,
        url: form.url.value,
        interval: parseInt(form.interval.value) || 60,
        tags: form.tags.value || '',
        body_check_enabled: form.body_check_enabled.checked,
        expected_body_regex: form.expected_body_regex.value || '',
        max_retries: parseInt(form.max_retries.value) || 0,
        alert_threshold_ms: parseInt(form.alert_threshold_ms.value) || null,
        alert_enabled: form.alert_enabled.checked,
      };
      try {
        const res = await fetch('/api/monitors', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (res.ok) {
          window.location.reload();
        } else {
          const err = await res.json();
          alert(err.error || 'Failed to add monitor');
        }
      } catch {
        alert('Network error');
      }
    });

    document.querySelectorAll('.delete-btn:not(.webhook-delete)').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!confirm('Delete this monitor?')) return;
        const id = btn.dataset.id;
        try {
          const res = await fetch('/api/monitors/' + id, { method: 'DELETE' });
          if (res.ok) window.location.reload();
        } catch {
          alert('Failed to delete');
        }
      });
    });

    document.getElementById('webhookForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const data = {
        url: form.url.value,
        events: form.events.value || 'down,up',
      };
      try {
        const res = await fetch('/api/webhooks', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (res.ok) {
          window.location.reload();
        } else {
          const err = await res.json();
          alert(err.error || 'Failed to add webhook');
        }
      } catch {
        alert('Network error');
      }
    });

    // Pause/Resume
    document.querySelectorAll('.pause-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id;
        try {
          const res = await fetch('/api/monitors/' + id + '/pause', { method: 'PATCH' });
          if (res.ok) window.location.reload();
        } catch { alert('Failed to pause'); }
      });
    });

    document.querySelectorAll('.resume-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id;
        try {
          const res = await fetch('/api/monitors/' + id + '/resume', { method: 'PATCH' });
          if (res.ok) window.location.reload();
        } catch { alert('Failed to resume'); }
      });
    });

    // Bulk delete
    const bulkDeleteBtn = document.getElementById('bulkDeleteBtn');
    function updateBulkBtn() {
      const checked = document.querySelectorAll('.monitor-checkbox:checked');
      bulkDeleteBtn.style.display = checked.length > 0 ? '' : 'none';
      bulkDeleteBtn.textContent = 'Delete Selected (' + checked.length + ')';
    }
    document.querySelectorAll('.monitor-checkbox').forEach(cb => {
      cb.addEventListener('change', updateBulkBtn);
    });
    bulkDeleteBtn.addEventListener('click', async () => {
      const checked = document.querySelectorAll('.monitor-checkbox:checked');
      const ids = Array.from(checked).map(cb => parseInt(cb.dataset.id));
      if (ids.length === 0) return;
      if (!confirm('Delete ' + ids.length + ' monitor(s)?')) return;
      try {
        const res = await fetch('/api/monitors/bulk', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ids }),
        });
        if (res.ok) window.location.reload();
      } catch { alert('Failed to delete'); }
    });

    document.querySelectorAll('.webhook-delete').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!confirm('Delete this webhook?')) return;
        const id = btn.dataset.id;
        try {
          const res = await fetch('/api/webhooks/' + id, { method: 'DELETE' });
          if (res.ok) window.location.reload();
        } catch {
          alert('Failed to delete');
        }
      });
    });

    // Channel management
    document.getElementById('channelForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const data = {
        type: form.type.value,
        config: { url: form.url.value },
      };
      try {
        const res = await fetch('/api/channels', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (res.ok) {
          window.location.reload();
        } else {
          const err = await res.json();
          alert(err.error || 'Failed to add channel');
        }
      } catch {
        alert('Network error');
      }
    });

    document.querySelectorAll('.channel-delete').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!confirm('Delete this notification channel?')) return;
        const id = btn.dataset.id;
        try {
          const res = await fetch('/api/channels/' + id, { method: 'DELETE' });
          if (res.ok) window.location.reload();
        } catch {
          alert('Failed to delete');
        }
      });
    });

    // API Key generation
    document.getElementById('apiKeyForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const data = { name: form.name.value };
      try {
        const res = await fetch('/api/keys', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (res.ok) {
          const result = await res.json();
          alert('API Key generated (copy it now — it won\'t be shown again):\n\n' + result.key);
          window.location.reload();
        } else {
          const err = await res.json();
          alert(err.error || 'Failed to generate key');
        }
      } catch {
        alert('Network error');
      }
    });

    // API Key revoke
    document.querySelectorAll('.api-key-delete').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!confirm('Revoke this API key?')) return;
        const id = btn.dataset.id;
        try {
          const res = await fetch('/api/keys/' + id, { method: 'DELETE' });
          if (res.ok) window.location.reload();
        } catch {
          alert('Failed to revoke');
        }
      });
    });
  </script>
</body>
</html>
