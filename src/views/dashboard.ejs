<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pulse — Uptime Monitor</title>
  <link rel="stylesheet" href="/style.css">
  <meta http-equiv="refresh" content="30">
</head>
<body>
  <header>
    <div class="header-content">
      <div class="logo">
        <span class="pulse-dot"></span>
        <h1>Pulse</h1>
      </div>
      <div class="header-right">
        <span class="real-time-clock" id="clock"></span>
        <p class="tagline">Uptime Monitoring</p>
      </div>
    </div>
  </header>

  <main>
    <!-- Stats Cards -->
    <section class="stats-grid">
      <div class="stat-card">
        <div class="stat-value"><%= stats.active_monitors || 0 %></div>
        <div class="stat-label">Active Monitors</div>
      </div>
      <div class="stat-card stat-card-uptime">
        <div class="stat-value stat-value-large"><%= stats.overall_uptime || '—' %><% if (stats.overall_uptime) { %>%<% } %></div>
        <div class="stat-label">Overall Uptime (24h)</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= stats.avg_response_time || '—' %><% if (stats.avg_response_time) { %><span class="stat-unit">ms</span><% } %></div>
        <div class="stat-label">Avg Response</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= stats.total_checks || 0 %></div>
        <div class="stat-label">Checks (24h)</div>
      </div>
    </section>

    <!-- Add Monitor Form -->
    <section class="add-monitor" id="addMonitorSection">
      <h2>Add Monitor <span class="shortcut-hint">(press <kbd>n</kbd>)</span></h2>
      <form id="addForm" class="add-form">
        <input type="text" name="name" placeholder="Name (e.g. Google)" required>
        <input type="url" name="url" placeholder="https://example.com" required>
        <input type="number" name="interval" placeholder="Interval (s)" value="60" min="10" max="3600">
        <input type="text" name="tags" placeholder="Tags (comma-separated)">
        <button type="submit">Add</button>
      </form>
    </section>

    <!-- Tag Filter Bar -->
    <% if (allTags.length > 0) { %>
      <section class="filter-bar">
        <span class="filter-label">Filter by tag:</span>
        <button class="tag-filter-btn active" data-tag="all">All</button>
        <% allTags.forEach(function(tag) { %>
          <button class="tag-filter-btn" data-tag="<%= tag %>"><%= tag %></button>
        <% }); %>
      </section>
    <% } %>

    <!-- Monitors Table -->
    <section class="monitors-section">
      <h2>Monitors</h2>
      <% if (monitors.length === 0) { %>
        <div class="empty-state">
          <p>No monitors yet. Add one above to get started.</p>
        </div>
      <% } else { %>
        <div class="monitors-grid">
          <% monitors.forEach(function(m) { %>
            <div class="monitor-card <%= m.latest_is_up === true ? 'up' : (m.latest_is_up === false ? 'down' : 'pending') %>" data-tags="<%= m.tags || '' %>">
              <div class="monitor-header">
                <div class="monitor-status">
                  <span class="status-indicator <%= m.latest_is_up === true ? 'up' : (m.latest_is_up === false ? 'down' : 'pending') %>"></span>
                  <h3><%= m.name %></h3>
                </div>
                <button class="delete-btn" data-id="<%= m.id %>" title="Delete">&times;</button>
              </div>
              <div class="monitor-url"><%= m.url %></div>
              <% if (m.tags) { %>
                <div class="tag-badges">
                  <% m.tags.split(',').map(function(t) { return t.trim(); }).filter(function(t) { return t; }).forEach(function(tag) { %>
                    <span class="tag-badge"><%= tag %></span>
                  <% }); %>
                </div>
              <% } %>
              <% if (sparklines[m.id] && sparklines[m.id].length > 1) { %>
                <div class="sparkline-container">
                  <% var points = sparklines[m.id]; var max = Math.max.apply(null, points); var min = Math.min.apply(null, points); var range = max - min || 1; %>
                  <svg viewBox="0 0 120 30" class="sparkline" preserveAspectRatio="none">
                    <polyline
                      fill="none"
                      stroke="var(--accent)"
                      stroke-width="1.5"
                      stroke-linejoin="round"
                      stroke-linecap="round"
                      points="<%= points.map(function(v, i) { return (i / (points.length - 1) * 120).toFixed(1) + ',' + (30 - ((v - min) / range) * 26 - 2).toFixed(1); }).join(' ') %>"
                    />
                  </svg>
                  <div class="sparkline-labels">
                    <span><%= min %>ms</span>
                    <span><%= max %>ms</span>
                  </div>
                </div>
              <% } %>
              <!-- 24h Uptime Bar -->
              <% if (uptimeBars[m.id]) { %>
                <div class="uptime-bar-container">
                  <div class="uptime-bar-label">24h Uptime</div>
                  <div class="uptime-bar">
                    <% uptimeBars[m.id].forEach(function(bucket) { %>
                      <div class="uptime-segment <%= bucket.uptime === -1 ? 'no-data' : (bucket.uptime >= 99 ? 'good' : (bucket.uptime >= 50 ? 'degraded' : 'bad')) %>" title="<%= bucket.hour.slice(11) %>:00 — <%= bucket.uptime === -1 ? 'No data' : bucket.uptime + '%' %>"></div>
                    <% }); %>
                  </div>
                  <div class="uptime-bar-axis">
                    <span>24h ago</span>
                    <span>Now</span>
                  </div>
                </div>
              <% } %>
              <div class="monitor-metrics">
                <div class="metric">
                  <span class="metric-value"><%= m.latest_is_up === true ? 'UP' : (m.latest_is_up === false ? 'DOWN' : '—') %></span>
                  <span class="metric-label">Status</span>
                </div>
                <div class="metric">
                  <span class="metric-value"><%= m.latest_response_time != null ? m.latest_response_time + 'ms' : '—' %></span>
                  <span class="metric-label">Response</span>
                </div>
                <div class="metric">
                  <span class="metric-value"><%= m.uptime_pct != null ? m.uptime_pct + '%' : '—' %></span>
                  <span class="metric-label">Uptime</span>
                </div>
                <div class="metric">
                  <span class="metric-value"><%= m.latest_status_code || '—' %></span>
                  <span class="metric-label">Code</span>
                </div>
              </div>
              <div class="monitor-footer">
                <span>Every <%= m.interval_seconds %>s</span>
                <a href="/history/<%= m.id %>" class="history-link">View History</a>
                <span><%= m.last_checked ? new Date(m.last_checked).toLocaleString() : 'Never' %></span>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>

    <!-- Incidents Timeline -->
    <section class="incidents-section">
      <h2>Recent Incidents</h2>
      <% if (incidents.length === 0) { %>
        <div class="empty-state">
          <p>No incidents recorded. All systems operational.</p>
        </div>
      <% } else { %>
        <div class="incidents-list">
          <% incidents.forEach(function(inc) { %>
            <div class="incident-card <%= inc.resolved_at ? 'resolved' : 'ongoing' %>">
              <div class="incident-status">
                <span class="incident-dot <%= inc.resolved_at ? 'resolved' : 'ongoing' %>"></span>
              </div>
              <div class="incident-details">
                <div class="incident-header">
                  <strong><%= inc.monitor_name %></strong>
                  <span class="incident-badge <%= inc.resolved_at ? 'resolved' : 'ongoing' %>">
                    <%= inc.resolved_at ? 'Resolved' : 'Ongoing' %>
                  </span>
                </div>
                <div class="incident-meta">
                  <span>Started: <%= new Date(inc.started_at).toLocaleString() %></span>
                  <% if (inc.resolved_at) { %>
                    <span>Resolved: <%= new Date(inc.resolved_at).toLocaleString() %></span>
                    <span>Duration: <%= inc.duration_seconds < 60 ? inc.duration_seconds + 's' : Math.floor(inc.duration_seconds / 60) + 'm ' + (inc.duration_seconds % 60) + 's' %></span>
                  <% } %>
                </div>
                <div class="incident-url"><%= inc.monitor_url %></div>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>

    <!-- Webhooks -->
    <section class="webhooks-section">
      <h2>Webhooks</h2>
      <form id="webhookForm" class="add-form">
        <input type="url" name="url" placeholder="https://example.com/webhook" required>
        <input type="text" name="events" placeholder="Events (default: down,up)" value="down,up">
        <button type="submit">Add Webhook</button>
      </form>
      <% if (webhooks.length > 0) { %>
        <div class="webhooks-list">
          <% webhooks.forEach(function(wh) { %>
            <div class="webhook-card">
              <div class="webhook-info">
                <div class="webhook-url"><%= wh.url %></div>
                <div class="webhook-meta">
                  <span class="webhook-events"><%= wh.events %></span>
                  <span>Added: <%= new Date(wh.created_at).toLocaleString() %></span>
                </div>
              </div>
              <button class="delete-btn webhook-delete" data-id="<%= wh.id %>" title="Delete">&times;</button>
            </div>
          <% }); %>
        </div>
      <% } %>
    </section>
  </main>

  <footer>
    <p>Pulse v1.2.0 &middot; Auto-refreshes every 30s</p>
  </footer>

  <script>
    // Real-time clock
    function updateClock() {
      const now = new Date();
      document.getElementById('clock').textContent = now.toLocaleTimeString();
    }
    updateClock();
    setInterval(updateClock, 1000);

    // Keyboard shortcut: 'n' to focus add form
    document.addEventListener('keydown', function(e) {
      if (e.key === 'n' && !e.ctrlKey && !e.metaKey && !e.altKey && e.target.tagName !== 'INPUT' && e.target.tagName !== 'TEXTAREA') {
        e.preventDefault();
        var nameInput = document.querySelector('#addForm input[name="name"]');
        if (nameInput) {
          document.getElementById('addMonitorSection').scrollIntoView({ behavior: 'smooth' });
          nameInput.focus();
        }
      }
    });

    // Tag filter
    document.querySelectorAll('.tag-filter-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.tag-filter-btn').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        var tag = btn.dataset.tag;
        document.querySelectorAll('.monitor-card').forEach(function(card) {
          if (tag === 'all') {
            card.style.display = '';
          } else {
            var cardTags = (card.dataset.tags || '').split(',').map(function(t) { return t.trim(); });
            card.style.display = cardTags.includes(tag) ? '' : 'none';
          }
        });
      });
    });

    document.getElementById('addForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const data = {
        name: form.name.value,
        url: form.url.value,
        interval: parseInt(form.interval.value) || 60,
        tags: form.tags.value || '',
      };
      try {
        const res = await fetch('/api/monitors', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (res.ok) {
          window.location.reload();
        } else {
          const err = await res.json();
          alert(err.error || 'Failed to add monitor');
        }
      } catch {
        alert('Network error');
      }
    });

    document.querySelectorAll('.delete-btn:not(.webhook-delete)').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!confirm('Delete this monitor?')) return;
        const id = btn.dataset.id;
        try {
          const res = await fetch('/api/monitors/' + id, { method: 'DELETE' });
          if (res.ok) window.location.reload();
        } catch {
          alert('Failed to delete');
        }
      });
    });

    document.getElementById('webhookForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const data = {
        url: form.url.value,
        events: form.events.value || 'down,up',
      };
      try {
        const res = await fetch('/api/webhooks', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (res.ok) {
          window.location.reload();
        } else {
          const err = await res.json();
          alert(err.error || 'Failed to add webhook');
        }
      } catch {
        alert('Network error');
      }
    });

    document.querySelectorAll('.webhook-delete').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!confirm('Delete this webhook?')) return;
        const id = btn.dataset.id;
        try {
          const res = await fetch('/api/webhooks/' + id, { method: 'DELETE' });
          if (res.ok) window.location.reload();
        } catch {
          alert('Failed to delete');
        }
      });
    });
  </script>
</body>
</html>
