<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pulse — SLA Report</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header>
    <div class="header-content">
      <div class="logo">
        <span class="pulse-dot"></span>
        <h1>Pulse</h1>
      </div>
      <nav class="header-nav">
        <a href="/">Dashboard</a>
        <a href="/status">Status</a>
        <a href="/reports" class="active">Reports</a>
      </nav>
    </div>
  </header>

  <main>
    <!-- Month Navigation -->
    <section class="report-header">
      <div class="month-nav">
        <a href="/reports?month=<%= prevMonth %>" class="nav-btn">&larr; Previous</a>
        <h2><%= monthLabel %></h2>
        <a href="/reports?month=<%= nextMonth %>" class="nav-btn">Next &rarr;</a>
      </div>
    </section>

    <!-- Summary Cards -->
    <section class="stats-grid">
      <div class="stat-card">
        <div class="stat-value"><%= summary.overallUptime !== null ? summary.overallUptime.toFixed(2) + '%' : '—' %></div>
        <div class="stat-label">Overall Uptime</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= summary.avgResponse || '—' %><% if (summary.avgResponse) { %><span class="stat-unit">ms</span><% } %></div>
        <div class="stat-label">Avg Response</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= summary.totalIncidents %></div>
        <div class="stat-label">Incidents</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= summary.totalDowntime %><span class="stat-unit">min</span></div>
        <div class="stat-label">Total Downtime</div>
      </div>
    </section>

    <!-- Per-Monitor Table -->
    <section class="report-table-section">
      <h2>Per-Monitor Breakdown</h2>
      <% if (monitors.length === 0) { %>
        <div class="empty-state"><p>No data for this month.</p></div>
      <% } else { %>
        <div class="table-wrapper">
          <table class="report-table">
            <thead>
              <tr>
                <th>Monitor</th>
                <th>Checks</th>
                <th>Uptime</th>
                <th>Avg (ms)</th>
                <th>P95 (ms)</th>
                <th>Max (ms)</th>
                <th>Incidents</th>
                <th>Downtime</th>
              </tr>
            </thead>
            <tbody>
              <% monitors.forEach(function(m) { %>
                <tr>
                  <td>
                    <div class="report-monitor-name"><%= m.name %></div>
                    <div class="report-monitor-url"><%= m.url %></div>
                  </td>
                  <td><%= m.total_checks || 0 %></td>
                  <td>
                    <span class="uptime-cell <%= m.uptime_pct >= 99.9 ? 'excellent' : (m.uptime_pct >= 99 ? 'good' : (m.uptime_pct >= 95 ? 'warning' : 'critical')) %>">
                      <%= m.uptime_pct !== null ? m.uptime_pct.toFixed(2) + '%' : '—' %>
                    </span>
                  </td>
                  <td><%= m.avg_response_ms || '—' %></td>
                  <td><%= m.p95_response_ms || '—' %></td>
                  <td><%= m.max_response_ms || '—' %></td>
                  <td><%= m.incidents_count || 0 %></td>
                  <td><%= m.total_downtime_minutes || 0 %>min</td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

        <!-- SLA Summary -->
        <div class="sla-summary">
          <h3>SLA Reference</h3>
          <div class="sla-grid">
            <div class="sla-item excellent">99.99% — 4.3min/month downtime</div>
            <div class="sla-item good">99.9% — 43.8min/month downtime</div>
            <div class="sla-item warning">99% — 7.3hr/month downtime</div>
            <div class="sla-item critical">95% — 1.5days/month downtime</div>
          </div>
        </div>
      <% } %>
    </section>

    <!-- Export -->
    <section class="export-section">
      <h2>Export Data</h2>
      <div class="export-buttons">
        <a href="/api/export/monitors" class="btn btn-export" download>Export Monitors (CSV)</a>
        <a href="/api/export/incidents" class="btn btn-export" download>Export Incidents (CSV)</a>
      </div>
    </section>
  </main>

  <footer>
    <p>Pulse v1.5.0 &middot; SLA Report</p>
  </footer>
</body>
</html>
