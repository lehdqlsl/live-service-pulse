<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>History — <%= monitor.name %> — Pulse</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <script>
    (function(){var t=localStorage.getItem('pulse-theme');if(!t){t=window.matchMedia('(prefers-color-scheme:light)').matches?'light':'dark'}document.documentElement.setAttribute('data-theme',t)})();
  </script>
  <header>
    <div class="header-content">
      <div class="logo">
        <span class="pulse-dot"></span>
        <h1>Pulse</h1>
      </div>
      <nav class="main-nav">
        <a href="/" class="nav-link">Dashboard</a>
        <a href="/status" class="nav-link">Status</a>
        <a href="/reports" class="nav-link">Report</a>
      </nav>
      <div class="header-right">
        <button class="theme-toggle" id="themeToggle" title="Toggle theme"></button>
        <a href="/" class="back-link">&larr; Back</a>
      </div>
    </div>
  </header>

  <main>
    <section class="history-header">
      <div class="history-header-row">
        <div>
          <h2>Check History: <%= monitor.name %></h2>
          <p class="history-url"><%= monitor.url %></p>
          <p class="history-summary"><%= total %> total checks</p>
        </div>
        <a href="/api/export/checks/<%= monitor.id %>?format=csv" class="export-btn">Export CSV</a>
      </div>
    </section>

    <% if (sslInfo) { %>
      <section class="ssl-info-section">
        <h3>SSL Certificate</h3>
        <div class="ssl-info-grid">
          <div class="ssl-info-item">
            <span class="ssl-info-label">Issuer</span>
            <span class="ssl-info-value"><%= sslInfo.issuer %></span>
          </div>
          <div class="ssl-info-item">
            <span class="ssl-info-label">Subject</span>
            <span class="ssl-info-value"><%= sslInfo.subject %></span>
          </div>
          <div class="ssl-info-item">
            <span class="ssl-info-label">Valid From</span>
            <span class="ssl-info-value"><%= new Date(sslInfo.valid_from).toLocaleDateString() %></span>
          </div>
          <div class="ssl-info-item">
            <span class="ssl-info-label">Valid To</span>
            <span class="ssl-info-value"><%= new Date(sslInfo.valid_to).toLocaleDateString() %></span>
          </div>
          <div class="ssl-info-item">
            <span class="ssl-info-label">Days Remaining</span>
            <% var days = sslInfo.days_remaining; %>
            <span class="ssl-badge <%= days > 30 ? 'ssl-green' : (days > 7 ? 'ssl-yellow' : 'ssl-red') %>"><%= days %> days</span>
          </div>
        </div>
      </section>
    <% } %>

    <!-- Response Time Chart (Time Series) -->
    <% if (timeseries && timeseries.length > 1) { %>
      <section class="timeseries-section">
        <h3>Response Time (Last 24h)</h3>
        <div class="timeseries-chart">
          <%
            var tsPoints = timeseries.filter(function(p) { return p.response_time_ms != null; });
            var tsMax = Math.max.apply(null, tsPoints.map(function(p) { return p.response_time_ms; }));
            var tsMin = Math.min.apply(null, tsPoints.map(function(p) { return p.response_time_ms; }));
            var tsRange = tsMax - tsMin || 1;
            var chartW = 800;
            var chartH = 200;
            var padL = 60;
            var padR = 10;
            var padT = 10;
            var padB = 30;
            var plotW = chartW - padL - padR;
            var plotH = chartH - padT - padB;
          %>
          <svg viewBox="0 0 <%= chartW %> <%= chartH %>" class="timeseries-svg" preserveAspectRatio="none">
            <!-- Grid lines -->
            <% for (var g = 0; g <= 4; g++) { %>
              <% var gy = padT + (plotH / 4) * g; %>
              <line x1="<%= padL %>" y1="<%= gy %>" x2="<%= chartW - padR %>" y2="<%= gy %>" stroke="var(--border)" stroke-width="0.5" />
              <text x="<%= padL - 5 %>" y="<%= gy + 4 %>" text-anchor="end" fill="var(--text-muted)" font-size="9">
                <%= Math.round(tsMax - (tsRange / 4) * g) %>ms
              </text>
            <% } %>
            <!-- Time axis labels -->
            <% var firstTime = new Date(tsPoints[0].checked_at).getTime(); %>
            <% var lastTime = new Date(tsPoints[tsPoints.length - 1].checked_at).getTime(); %>
            <% var timeRange = lastTime - firstTime || 1; %>
            <% for (var t = 0; t <= 4; t++) { %>
              <% var tx = padL + (plotW / 4) * t; %>
              <% var tTime = new Date(firstTime + (timeRange / 4) * t); %>
              <text x="<%= tx %>" y="<%= chartH - 5 %>" text-anchor="middle" fill="var(--text-muted)" font-size="9">
                <%= tTime.toLocaleTimeString([], {hour: '2-digit', minute: '2-digit'}) %>
              </text>
            <% } %>
            <!-- Data line -->
            <polyline
              fill="none"
              stroke="var(--accent)"
              stroke-width="1.5"
              stroke-linejoin="round"
              stroke-linecap="round"
              points="<%= tsPoints.map(function(p, i) {
                var x = padL + (i / (tsPoints.length - 1)) * plotW;
                var y = padT + plotH - ((p.response_time_ms - tsMin) / tsRange) * plotH;
                return x.toFixed(1) + ',' + y.toFixed(1);
              }).join(' ') %>"
            />
            <!-- Data points with tooltips -->
            <% tsPoints.forEach(function(p, i) {
              var x = padL + (i / (tsPoints.length - 1)) * plotW;
              var y = padT + plotH - ((p.response_time_ms - tsMin) / tsRange) * plotH;
            %>
              <circle cx="<%= x.toFixed(1) %>" cy="<%= y.toFixed(1) %>" r="<%= tsPoints.length > 100 ? 1 : 2.5 %>" fill="var(--accent)" opacity="0.7">
                <title><%= new Date(p.checked_at).toLocaleString() %> — <%= p.response_time_ms %>ms</title>
              </circle>
            <% }); %>
          </svg>
        </div>
      </section>
    <% } %>

    <!-- Response Time Histogram -->
    <section class="histogram-section">
      <h3>Response Time Distribution</h3>
      <div class="histogram">
        <% var maxCount = Math.max.apply(null, histogram.map(function(b) { return b.count; })) || 1; %>
        <% histogram.forEach(function(bucket) { %>
          <div class="histogram-row">
            <span class="histogram-label"><%= bucket.range %></span>
            <div class="histogram-bar-track">
              <div class="histogram-bar" style="width: <%= (bucket.count / maxCount * 100).toFixed(1) %>%"></div>
            </div>
            <span class="histogram-count"><%= bucket.count %></span>
          </div>
        <% }); %>
      </div>
    </section>

    <section class="history-table-section">
      <table class="history-table">
        <thead>
          <tr>
            <th>Timestamp</th>
            <th>Status</th>
            <th>Status Code</th>
            <th>Response Time</th>
            <th>Error</th>
          </tr>
        </thead>
        <tbody>
          <% checks.forEach(function(c) { %>
            <tr class="<%= c.is_up ? 'row-up' : 'row-down' %>">
              <td><%= new Date(c.checked_at).toLocaleString() %></td>
              <td>
                <span class="status-badge <%= c.is_up ? 'up' : 'down' %>">
                  <%= c.is_up ? 'UP' : 'DOWN' %>
                </span>
              </td>
              <td><%= c.status_code || '—' %></td>
              <td><%= c.response_time_ms != null ? c.response_time_ms + 'ms' : '—' %></td>
              <td><% if (c.error_message) { %><span class="error-text"><%= c.error_message %></span><% } else { %>—<% } %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>

      <% if (pages > 1) { %>
        <div class="pagination">
          <% if (page > 1) { %>
            <a href="/history/<%= monitor.id %>?page=<%= page - 1 %>" class="page-link">&larr; Prev</a>
          <% } %>
          <span class="page-info">Page <%= page %> of <%= pages %></span>
          <% if (page < pages) { %>
            <a href="/history/<%= monitor.id %>?page=<%= page + 1 %>" class="page-link">Next &rarr;</a>
          <% } %>
        </div>
      <% } %>
    </section>
  </main>

  <footer>
    <p>Pulse v2.1.0</p>
  </footer>
  <script>
    (function(){
      var btn = document.getElementById('themeToggle');
      function updateBtn(){btn.textContent = document.documentElement.getAttribute('data-theme') === 'light' ? '\u2600\uFE0F' : '\uD83C\uDF19';}
      updateBtn();
      btn.addEventListener('click', function(){
        var next = document.documentElement.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('pulse-theme', next);
        updateBtn();
      });
    })();
  </script>
</body>
</html>
